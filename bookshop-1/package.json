{
  "name": "bookshop-1",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/cds-common-content": "^3.1.0",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
"cds": {
  "requires": {
    "db": {
      "kind": "hana-cloud",
      "[development]": {
        "kind": "sqlite"
      }
    },
    "[production]": {
      "auth": "xsuaa"
    },
    "messaging": {
      "kind": "enterprise-messaging"
    },
    "html5-repo": true
  },
  "model": {
    "[production]": [
      "db", "srv", "app", "db/hana"
    ],
    "[development]": [
      "db", "srv", "app", "db/sqlite"
    ]
  }
}
}